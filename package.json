{
  "name": "bondscope",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && python3 -m uvicorn main:app --reload --port 8000",
    "install": "npm run install:frontend",
    "install:frontend": "cd frontend && npm install",
    "install:backend": "cd backend && python3 -m pip install -r requirements.txt",
    "lint": "npm run lint:frontend",
    "lint:frontend": "cd frontend && npm run lint",
    "test": "cd backend && python3 -m pytest tests/ -v",
    "test:backend": "cd backend && python3 -m pytest tests/ -v"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
